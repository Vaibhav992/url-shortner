# Copy this file to .env and fill in your values (do not commit .env)

# Profile
SPRING_PROFILES_ACTIVE=prod

# Server
PORT=8080

# Database — JDBC URL required (NOT psql command)
# Local Postgres example:
# DATABASE_URL=jdbc:postgresql://localhost:5432/urlshortener
# Neon example:
# DATABASE_URL=jdbc:postgresql://ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=jdbc:postgresql://localhost:5432/urlshortener
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Application
BASE_URL=http://localhost:8080

# Alias generation (Base62, length 3–32)
APP_ALIAS_AUTO_LENGTH=7

# Default URL expiry when client omits expiresAt (seconds)
APP_TTL_DEFAULT_SECONDS=60

# Cache
APP_CACHE_MAX_SIZE=10000
APP_CACHE_EXPIRE_MINUTES=10

# Logging
LOG_LEVEL=INFO
